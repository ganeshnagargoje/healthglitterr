
# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Optional: Specify OpenAI organization ID
# OPENAI_ORGANIZATION=your-org-id-here

# Optional: Specify default model for LLM extraction
# LLM_MODEL=gpt-4o-mini

# Optional: Anthropic API key (if using Claude)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Other LLM provider keys
# COHERE_API_KEY=your-cohere-api-key-here
# HUGGINGFACE_API_KEY=your-huggingface-api-key-here

# PostgreSQL Database Configuration
POSTGRES_DB=medical_health_review
POSTGRES_USER=your-postgres-user
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Database URL
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ============================================
# Application Configuration
# ============================================
APP_PORT=8000
APP_ENV=development

# API Backend Configuration
API_HOST=localhost
API_PORT=8000
API_DEBUG=false

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE_MB=10

# Internationalization
DEFAULT_LANGUAGE=en

# Security Configuration
SESSION_TIMEOUT_MINUTES=30
SECRET_KEY=change-this-in-production-to-a-random-secret-key

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-secret-here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Logging Configuration
LOG_LEVEL=INFO

# React Frontend Configuration
REACT_APP_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:8000

# pgAdmin Configuration (optional)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050


